<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow serial port access -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow execution of unsigned code (PyInstaller requirement) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- Allow debugging (required for some PyQt operations) -->
    <key>com.apple.security.cs.debugger</key>
    <true/>
    
    <!-- Allow reading files from user-selected directories -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- Allow network access (for cover downloads) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
</dict>
</plist>
